generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String?
  provider     String?      // 'google' | null (email/password)
  avatarUrl    String?
  createdAt    DateTime     @default(now())
  wallets      Wallet[]
}

model Wallet {
  id                      String                   @id @default(cuid())
  userId                  String
  name                    String
  createdAt               DateTime                 @default(now())
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets                  Asset[]
  transactions            Transaction[]
  dividends               Dividend[]
  projection              Projection?
  ceilingPriceProjections CeilingPriceProjection[]
}

model Asset {
  id             String        @id @default(cuid())
  walletId       String
  ticker         String
  name           String        @default("")
  assetClass     AssetClass
  subtype        String?
  sector         String?
  // Renda Fixa
  issuer         String?
  indexer        String?
  rate           Decimal?
  fixedForm      String?
  dailyLiquidity Boolean?
  maturityDate   DateTime?
  createdAt      DateTime      @default(now())
  wallet         Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  dividends      Dividend[]

  @@unique([walletId, ticker])
}

model Transaction {
  id        String          @id @default(cuid())
  walletId  String
  assetId   String
  type      TransactionType
  date      DateTime
  quantity  Decimal
  unitPrice Decimal
  fees      Decimal         @default(0)
  notes     String?
  createdAt DateTime        @default(now())
  wallet    Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  asset     Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Dividend {
  id           String       @id @default(cuid())
  walletId     String
  assetId      String
  type         DividendType
  exDate       DateTime
  payDate      DateTime
  valuePerUnit Decimal
  quantity     Decimal
  totalValue   Decimal
  notes        String?
  createdAt    DateTime     @default(now())
  wallet       Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  asset        Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, exDate, type])
}

model Projection {
  id              String   @id @default(cuid())
  walletId        String   @unique
  patrimonio      String
  anos            Int
  defaultAporte   String
  defaultRent     String
  aporteOverrides Json     @default("{}")
  rentOverrides   Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model CeilingPriceProjection {
  id                String   @id @default(cuid())
  walletId          String
  ticker            String
  dyEsperado        String   // % anual (ex: "7.00")
  margemCrescimento String   // % crescimento de lucro (ex: "5.00")
  payout            String   // % payout esperado (ex: "60.00")
  lucroAnterior     String   // R$ lucro líquido anterior (ex: "620000000")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  wallet            Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, ticker])
  @@index([walletId])
}

enum AssetClass {
  FII
  STOCK
  FIXED_INCOME
  TREASURY
  CRYPTO
}

enum TransactionType {
  BUY
  SELL
}

enum DividendType {
  DIVIDEND
  JCP
  INCOME
  AMORTIZATION
  SUBSCRIPTION
}
